<target name="dist" description="Builds a tar zip archive of all sources">
   <mkdir dir="build"/>
   <tstamp/>
   <zip zipfile="build/myos3x-${DSTAMP}.zip" basedir="${basedir}" update="false"
      excludes="build/**,**/*.class,**/*.jar,**/*.exe"/>
</target>

<target name="buildnumber">
	<!-- Maintain build number -->
	<propertyfile
    	file="build.data"
	    comment="My properties">
		<entry key="builddate" type="date" value="now" pattern="dd-MM-yyyy HH:mm:ss"/>
		<entry key="build" type="int" default="0" operation="+"/>
	</propertyfile>	
	<replace 
	    file="build/gen_src/myosconfig.h"
	    propertyFile="build.data">
	  <replacefilter token="@build@"  	 property="build"/>
	  <replacefilter token="@builddate@" property="builddate"/>
	</replace>
</target>

<target name="debug" description="Compiles the MyOS kernel with DEBUG flags">
	<property name="DIR" value="build/debug"/>

	<!--antcall target="refresh_xslts"/-->
	<antcall target="config_xslt"/>
	<antcall target="buildnumber"/>
	
	<!--antcall target="asm.compile"/-->
	<antcall target="cppbuild">
	   <param name="C++.FLAGS" value="-O2 -DDEBUG"/>
	</antcall>
	<parallel threadCount="${build.threads}" failonany="true">
		<antcall target="makelib">
		  <param name="DIR" value="${DIR}/Core"/>
		</antcall>	
		<antcall target="makelib">
		  <param name="DIR" value="${DIR}/Atmosphere"/>
		</antcall>
	</parallel>
	<parallel threadCount="${build.threads}" failonany="true">
		<antcall target="link"/>
		<antcall target="link.module">
		  <param name="DIR" value="${DIR}/Atmosphere"/>
		</antcall>
	</parallel>
	<antcall target="zip"/>
	<antcall target="createflopimage"/>
</target>
	
<target name="debug_mod" depends="debug" description="For module debugging">
	<delete file="${DIR}/module.elf"/>
	
	<antcall target="makelib">
	   <param name="DIR" value="${DIR}/TestModule"/>
	</antcall>
	<antcall target="link.module">
	   <param name="DIR" value="${DIR}/TestModule"/>
	</antcall>
	<antcall target="zip"/>
	<antcall target="createflopimage"/>	
</target>
	

<target name="optimize" description="Compiles the MyOS kernel with OPTIMIZE flags">
	<property name="DIR" value="build/optimize"/>

	<!--antcall target="refresh_xslts"/-->
	<antcall target="config_xslt"/>
	<antcall target="buildnumber"/>
	
	<!--antcall target="asm.compile"/-->
	<antcall target="cppbuild">
	   <param name="C++.FLAGS" value="-O4 -mtune=pentium4"/>
    </antcall>
	<parallel threadCount="${build.threads}" failonany="true">
		<antcall target="makelib">
			<param name="DIR" value="${DIR}/Core"/>
		</antcall>
		<antcall target="makelib">
		  <param name="DIR" value="${DIR}/Atmosphere"/>
		</antcall>
	</parallel>
	<parallel threadCount="${build.threads}" failonany="true">
		<antcall target="link"/>
		<antcall target="link.module">
		  <param name="DIR" value="${DIR}/Atmosphere"/>
		</antcall>
	</parallel>
	<antcall target="zip"/>
	<antcall target="createflopimage"/>
</target>


<target name="compileonly" description="For checking C++ syntax">
	<property name="DIR" value="build/debug"/>

	<!-- Force rechecking *every* .cpp file if any .h file under /src changed -->
	<dependset>
		<srcfileset dir="src" includes="**/*.h,**/*.inc,**/*.hpp"/>
		<srcfileset dir="xml" includes="**/*.xml"/>
  		<targetfileset dir="${DIR}" includes="**/*.o"/>
	</dependset>

	<antcall target="cxx.compile">
		<param name="C++.FLAGS" value="-O -DDEBUG -mregparm=3 -fno-rtti -fconserve-space -fsyntax-only"/>
	</antcall>
</target>

