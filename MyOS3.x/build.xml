<project name="MyOS3.x" default="debug" xmlns:doxygen="antlib:org.doxygen.tools">

<property name="src.dir" location="code/Core/src"/>
<!-- Maximum number of independent build branches Ant may execute at once.
     Override on the command line with, for example, -Dbuild.threads=2. -->
<property name="build.threads" value="3"/>
	
<path id="cp">
   <fileset dir="buildtools/lib">
      <include name="*.jar"/>
   </fileset>
</path>

<target name="all" depends="debug"/>
	
<target name="init">
	<mkdir dir="${DIR}"/>
	<mkdir dir="build/gen_src"/>

	<!-- prepare helper classes -->
    <javac destdir="build/gen_src" debug="on" optimize="off" source="1.4" classpathref="cp">
		<classpath>
			<!-- <fileset dir="lib" includes="*.jar"/> -->
		</classpath>
		<src path="buildtools/src"/>
    </javac>

</target>

<target name="xslt">
   <echo message="Processing ${XSLFILE} on ${XMLFILE}"/>

   <java classname="net.sf.saxon.Transform" fork="true" dir="build/gen_src" failonerror="true">
      <classpath>
         <fileset dir="buildtools/lib" includes="*.jar"/>
         <pathelement path="build/gen_src"/>
      </classpath>
      <arg value="-o"/>
      <arg path='build/${XSLFILE}.out'/>
      <arg path='${XMLFILE}'/>
      <arg path='xslt/${XSLFILE}'/>
   </java>
   <!--style
      processor="org.xmLP.ant.taskdefs.optional.Saxon7Liaison"
      basedir="xml" destdir="build/jsp" extension=".jsp" style="${XSLFILE}"
      includes="structure.xml">
   </style-->
</target>

<target name="interfaces_xslt" unless="interfaces.up2date">
   <taskdef resource="net/sf/antcontrib/antcontrib.properties"/>
   <foreach param="XMLFILE" target="xslt">
      <param name="XSLFILE" value="cg_interface.xsl"/>
      <path>
         <fileset dir="xml/Interfaces" includes="*.xml"/>
      </path>
   </foreach>
   <touch file="${DIR}/interfaces.generated"/>
</target>

<target name="devices_xslt" unless="devices.up2date">
   <taskdef resource="net/sf/antcontrib/antcontrib.properties"/>
   <foreach param="XMLFILE" target="xslt">
      <param name="XSLFILE" value="cg_device.xsl"/>
      <path>
         <fileset dir="xml/Devices" includes="*.xml"/>
      </path>
   </foreach>
   <touch file="${DIR}/devices.generated"/>
</target>

<target name="components_xslt" unless="components.up2date">
   <taskdef resource="net/sf/antcontrib/antcontrib.properties"/>
   <foreach param="XMLFILE" target="xslt">
      <param name="XSLFILE" value="cg_component.xsl"/>
      <path>
         <fileset dir="xml/Components" includes="*.xml"/>
      </path>
   </foreach>
   <touch file="${DIR}/components.generated"/>
</target>

<target name="services_xslt" unless="services.up2date">
   <taskdef resource="net/sf/antcontrib/antcontrib.properties"/>
   <foreach param="XMLFILE" target="xslt">
      <param name="XSLFILE" value="cg_service.xsl"/>
      <path>
         <fileset dir="xml/Services" includes="*.xml"/>
      </path>
   </foreach>
   <touch file="${DIR}/services.generated"/>
</target>
	
	
<target name="drivers_xslt" unless="drivers.up2date">
   <taskdef resource="net/sf/antcontrib/antcontrib.properties"/>
   <foreach param="XMLFILE" target="xslt">
      <param name="XSLFILE" value="cg_driver.xsl"/>
      <path>
         <fileset dir="xml/Drivers" includes="*.xml"/>
      </path>
   </foreach>
   <touch file="${DIR}/drivers.generated"/>
</target>
		
<target name="containers_xslt" unless="containers.up2date">
   <taskdef resource="net/sf/antcontrib/antcontrib.properties"/>
   <foreach param="XMLFILE" target="xslt">
      <param name="XSLFILE" value="cg_container.xsl"/>
      <path>
         <fileset dir="xml/Containers" includes="*.xml"/>
      </path>
   </foreach>
   <touch file="${DIR}/containers.generated"/>
</target>

<target name="config_xslt" depends="init">
   <antcall target="xslt">
      <param name="XSLFILE" value="cg_config.xsl"/>
	  <param name="XMLFILE" value="xml/myosconfig.xml"/>
   </antcall>
</target>


<target name="refresh_xslts" depends="init">
   <uptodate property="interfaces.up2date" targetfile="${DIR}/interfaces.generated">
      <srcfiles dir="xslt" includes="cg_interface.xsl"/>
      <srcfiles dir="xml/Interfaces" includes="*.xml"/>
      <srcfiles dir="xml" includes="myosconfig.xml"/>
   </uptodate>
   <uptodate property="devices.up2date" targetfile="${DIR}/devices.generated">
      <srcfiles dir="xslt" includes="cg_device.xsl"/>
      <srcfiles dir="xml/Devices" includes="*.xml"/>
      <srcfiles dir="xml" includes="myosconfig.xml"/>
   </uptodate>
   
   <uptodate property="components.up2date" targetfile="${DIR}/components.generated">
      <srcfiles dir="xslt" includes="cg_component.xsl"/>
      <srcfiles dir="xml/Components" includes="*.xml"/>
      <srcfiles dir="xml" includes="myosconfig.xml"/>      
   </uptodate>
   <uptodate property="services.up2date" targetfile="${DIR}/services.generated">
      <srcfiles dir="xslt" includes="cg_service.xsl"/>
      <srcfiles dir="xml/Services" includes="*.xml"/>
      <srcfiles dir="xml" includes="myosconfig.xml"/>      
   </uptodate>	
   <uptodate property="drivers.up2date" targetfile="${DIR}/drivers.generated">
      <srcfiles dir="xslt" includes="cg_driver.xsl"/>
      <srcfiles dir="xml/Drivers" includes="*.xml"/>
      <srcfiles dir="xml" includes="myosconfig.xml"/>      
   </uptodate>	
   <uptodate property="containers.up2date" targetfile="${DIR}/containers.generated">
      <srcfiles dir="xslt" includes="cg_container.xsl"/>
      <srcfiles dir="xml/Containers" includes="*.xml"/>
      <srcfiles dir="xml" includes="myosconfig.xml"/>      
   </uptodate>   
   <parallel>
   <antcall target="interfaces_xslt"/>
   <antcall target="devices_xslt"/>
   <antcall target="components_xslt"/>
   <antcall target="services_xslt"/>
   <antcall target="drivers_xslt"/>
   <antcall target="containers_xslt"/>
   <antcall target="config_xslt"/>
   </parallel>   
</target>

<target name="clean">
	<delete dir="build"/>
</target>

<target name="tools">
   <!--property name="mingw.dir" location="C:\cygwin\home\Jeroen\thisiscool-gcc\gcc-4.0"/-->
   
	<property name="cygwin.dir" location="C:/cygwin"/>
	<property name="gcc.dir" location="${cygwin.dir}/usr/local/bin"/>
	<!--property name="gcc.dir" location="${cygwin.dir}/home/Jeroen/gcc-4.2.3/host-i686-pc-cygwin/gcc"/-->
	
	<!--property name="gcc.dir" location="${cygwin.dir}/bin"/-->
   
   <property name="CXX"  location="${gcc.dir}/g++"/>
   <!--property name="CXX"  location="buildtools/g++"/-->
   
   
   <property name="GCC"  location="${gcc.dir}/gcc"/>
   <!--property name="GCCLIBDIR"  location="${gcc.dir}/../lib/gcc/i686-pc-cygwin/4.3.1"/-->
	
   <!--property name="GCC"  location="e:\cygwin\usr\local\gcc-3.4.3\bin\gcc"/-->
   
