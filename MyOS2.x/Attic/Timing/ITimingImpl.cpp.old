void 
ITimingImpl::deinit( IContext& context )
{

}


// virtual 
myos_result_t
ITimingImpl::scheduleCallback( TimerEvent& e, u32 afterUs  )  {
   // XX calling overhead
   theTimer.addEvent( e, afterUs );
   return E_MYOS_SUCCESS;  // XX check result of addEvent
}

